# Copy to .env.docker and adjust values for your machine.
# Compose project name (used for container/volume/network names)
# Keep unique on the same machine to avoid reusing old volumes unexpectedly.
COMPOSE_PROJECT_NAME=cloudmusic
IMAGE_TAG=local
TZ=Asia/Shanghai

# Exposed ports on host
GATEWAY_PORT=8080
MYSQL_EXPOSE_PORT=3307
REDIS_EXPOSE_PORT=6380

# Database settings used by MySQL container and generated app config
MYSQL_ROOT_PASSWORD=change_me_please
MYSQL_DATABASE=music_users

# Optional Redis password (leave blank to disable auth)
REDIS_PASSWORD=

# Host static resource directories (relative to repo root by default)
HOST_UPLOAD_DIR=./.data/uploads
HOST_TRANSCODED_AUDIO_DIR=./.data/transcoded_audio
HOST_VIDEO_DIR=./.data/video
HOST_HLS_DIR=./.data/uploads_hls

# Public URL used in response fields (stream_url/cover_url/video url)
SERVER_HOST=0.0.0.0
SERVER_PORT=18080
SERVER_PUBLIC_HOST=localhost
# Optional: if not set, defaults to GATEWAY_PORT
# SERVER_PUBLIC_PORT=8080
# Optional: if not set, defaults to http://localhost:${SERVER_PUBLIC_PORT}
# SERVER_PUBLIC_BASE_URL=http://localhost:8080
# Optional: static media/CDN base URL for /uploads resources; defaults to SERVER_PUBLIC_BASE_URL
# SERVER_MEDIA_PUBLIC_BASE_URL=http://cdn.example.com
# Optional: static media/CDN base URL for /audio-cache resources; defaults to SERVER_MEDIA_PUBLIC_BASE_URL
# SERVER_TRANSCODED_AUDIO_PUBLIC_BASE_URL=http://cdn.example.com

# Optional custom schema names
DB_SCHEMA_PROFILE=music_profile
DB_SCHEMA_CATALOG=music_users
DB_SCHEMA_MEDIA=music_media

# Optional external music provider credentials
JAMENDO_CLIENT_ID=

# Optional Go module proxy settings used during Docker build
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn
GOPRIVATE=

# Admin console credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_SESSION_TTL_MINUTES=1440
